{
  "version": 6,

  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 29,
    "patch": 0
  },

  "configurePresets": [
    {
      "name": "base",
      "inherits": "base-user",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/bin/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_OSX_SYSROOT": {
          "type": "PATH",
          "value": "/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk"
        }
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "base-apple",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "base-apple",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "displayName": "Release",
      "configurePreset": "release"
    }
  ]
}